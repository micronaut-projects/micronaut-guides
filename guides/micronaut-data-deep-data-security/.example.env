# Example environment for Employee Records API
# Copy to ".env" and fill real values. .env is git-ignored.
# Load with: set -a; source .env; set +a    (bash/zsh)

# Tenant ID of the Azure App Registrations for an Oracle Database instance and
# this Micronaut application.
HRAPP_TENANT_ID='xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'

# Application ID URI of a registered application for an Oracle Database instance
DB_APP_ID_URI='https://example.onmicrosoft.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx'

# HR App (both JDBC provider client-id and Micronaut OAuth2 client-id)
HRAPP_CLIENT_ID='<azure-app-client-id>'
HRAPP_CLIENT_SECRET='<azure-app-client-secret>'   # SECRET

# OAuth 2.0 endpoints and scope for client credentials flow
# Purpose: Obtain access tokens for the HR App (client_credentials).
HRAPP_SCOPE="$DB_APP_ID_URI/.default"

# Oracle wallet / trust store (SSO wallet .sso file)
ORACLE_WALLET_TRUSTSTORE='/path/to/cwallet.sso'